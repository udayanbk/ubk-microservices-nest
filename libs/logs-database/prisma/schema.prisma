datasource db {
  provider = "postgresql"
  url      = env("LOGS_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/logs-client"
}

model DlqEvent {
  id        String   @id @default(uuid())
  topic     String
  payload   Json
  error     String
  service   String
  createdAt DateTime @default(now())
}